<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:NoCloudware.UI.Core.ViewModels;assembly=NoCloudware.UI.Core">

    <DataTemplate x:Key="QueueItemTemplate" DataType="{x:Type vm:BaseFileItem}">
        <Grid Margin="0,1,0,1" MinHeight="26">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0"
                      IsChecked="{Binding IsSelected}"
                      VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding FileName}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Margin="4,0,4,0"/>

            <TextBlock Grid.Column="2"
                       Text="{Binding SourceText}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>

            <ProgressBar Grid.Column="3"
                         Value="{Binding Progress}"
                         Minimum="0" Maximum="100"
                         Height="14"
                         VerticalAlignment="Center"
                         Visibility="{Binding ProgressBarVisible, Converter={StaticResource ProgressVisibilityConverter}}"
                         Foreground="{DynamicResource AccentBrush}"
                         Background="{DynamicResource SurfaceAltBrush}"
                         BorderThickness="0"
                         Margin="2,0"/>

            <TextBlock Grid.Column="4"
                       Text="{Binding StatusText}"
                       Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       TextAlignment="Right"
                       Margin="0,0,4,0"/>

            <!-- Expand/Collapse (+/-) for playlists -->
            <Button Grid.Column="5"
                    Content="{Binding ResultMessage}"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="{Binding Converter={StaticResource TreeItemIconForegroundConverter}}"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Width="16" Height="16"
                    Padding="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding Converter={StaticResource TreeItemIconVisibilityConverter}}"
                    Command="{Binding TogglePlaylistCommand}"
                    ToolTip="Expand/Collapse"/>

            <!-- Delete (✕) for regular items -->
            <Button Grid.Column="6"
                    Content="✕"
                    FontSize="11"
                    Foreground="{DynamicResource StatusErrorBrush}"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    Width="16" Height="16"
                    Padding="0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="{Binding Converter={StaticResource DeleteIconVisibilityConverter}}"
                    Command="{Binding DeleteCommand}"
                    ToolTip="Remove"/>
        </Grid>
    </DataTemplate>
</ResourceDictionary>