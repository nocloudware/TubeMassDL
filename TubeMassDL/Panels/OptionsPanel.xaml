<UserControl x:Class="TubeMassDL.Panels.OptionsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="{DynamicResource WindowBackgroundBrush}">
        <StackPanel Margin="10" MinWidth="250">
            <!-- Capture toggle and Antiblock together at top -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Center">
                <TextBlock x:Name="CaptureLabel" Text="📋 Captura" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <CheckBox x:Name="CaptureToggle" IsChecked="True" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <CheckBox x:Name="AntiBlockCheckBox" Content="🛡️ Antibloqueo" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" IsChecked="True" VerticalAlignment="Center"/>
            </StackPanel>

            <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,12"/>

            <!-- Manual URL -->
            <TextBlock x:Name="UrlLabel" Text="URL manual" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UrlTextBox" Grid.Column="0" Background="{DynamicResource SurfaceAltBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="8,6" FontSize="13"/>
                <ui:Button Grid.Column="1" Content="+" Margin="6,0,0,0" Padding="10,6" Click="OnAddUrlClick"/>
            </Grid>

            <!-- Type -->
            <TextBlock x:Name="TypeLabel" Text="Tipo" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <ComboBox x:Name="TypeComboBox"
                      Background="{DynamicResource SurfaceAltBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      Padding="8,6" FontSize="13"
                      SelectedIndex="0" Margin="0,0,0,8"
                      SelectionChanged="OnTypeChanged">
                <ComboBoxItem>🎬 Video</ComboBoxItem>
                <ComboBoxItem>🎵 Audio</ComboBoxItem>
            </ComboBox>

            <!-- Quality -->
            <TextBlock x:Name="QualityLabel" Text="Calidad" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <ComboBox x:Name="QualityComboBox"
                      Background="{DynamicResource SurfaceAltBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      Padding="8,6" FontSize="13"
                      SelectedIndex="0" Margin="0,0,0,8">
                <ComboBoxItem>4K</ComboBoxItem>
                <ComboBoxItem>1080p</ComboBoxItem>
                <ComboBoxItem>720p</ComboBoxItem>
                <ComboBoxItem>480p</ComboBoxItem>
                <ComboBoxItem>360p</ComboBoxItem>
            </ComboBox>

            <!-- Format -->
            <TextBlock x:Name="FormatLabel" Text="Formato" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <ComboBox x:Name="FormatComboBox"
                      Background="{DynamicResource SurfaceAltBrush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      Padding="8,6" FontSize="13"
                      SelectedIndex="0" Margin="0,0,0,12">
                <ComboBoxItem>mp4</ComboBoxItem>
                <ComboBoxItem>webm</ComboBoxItem>
                <ComboBoxItem>mkv</ComboBoxItem>
                <ComboBoxItem>avi</ComboBoxItem>
            </ComboBox>

            <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,12"/>

            <!-- Action buttons - centered, same size -->
            <!-- Download button centered on its own line -->
            <ui:Button x:Name="DownloadButton" Appearance="Primary"
                       Margin="0,0,0,8" Height="40" Width="200" FontSize="14"
                       HorizontalAlignment="Center" Click="OnDownloadClick"
                       Content="DESCARGAR">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowDownload20"/>
                </ui:Button.Icon>
            </ui:Button>

            <!-- Pause and Stop buttons centered on next line -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <ui:Button x:Name="PauseButton" Appearance="Secondary"
                           IsEnabled="False" Width="120" Height="40" FontSize="14"
                           Margin="0,0,8,0" Click="OnPauseClick"
                           Content="PAUSAR">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Pause20"/>
                    </ui:Button.Icon>
                </ui:Button>
                <ui:Button x:Name="StopButton" Appearance="Secondary"
                           IsEnabled="False" Width="120" Height="40" FontSize="14"
                           Click="OnStopClick"
                           Content="DETENER">
                    <ui:Button.Icon>
                        <ui:SymbolIcon Symbol="Stop20"/>
                    </ui:Button.Icon>
                </ui:Button>
            </StackPanel>

            <!-- Output folder field REMOVED as requested -->
        </StackPanel>
    </ScrollViewer>
</UserControl>