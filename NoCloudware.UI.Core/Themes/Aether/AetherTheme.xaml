<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="AetherButtons.xaml"/>
        <ResourceDictionary Source="AetherWindow.xaml"/>
        <ResourceDictionary Source="AetherTypography.xaml"/>
        <ResourceDictionary Source="AetherDropZone.xaml"/>
        <ResourceDictionary Source="AetherFileList.xaml"/>
        <ResourceDictionary Source="AetherStatusBar.xaml"/>
        <ResourceDictionary Source="AetherAnimations.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <SolidColorBrush x:Key="CloseButtonBg" Color="#E81123"/>
    <SolidColorBrush x:Key="MinimizeButtonBg" Color="#555555"/>

    <LinearGradientBrush x:Key="StatusBarGlow" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#4A9EFF" Offset="0.0"/>
        <GradientStop Color="#7CBA3D" Offset="0.33"/>
        <GradientStop Color="#F0C040" Offset="0.66"/>
        <GradientStop Color="#4A9EFF" Offset="1.0"/>
    </LinearGradientBrush>

    <DropShadowEffect x:Key="IconShadow" Color="Black" Opacity="0.3"
                      BlurRadius="8" ShadowDepth="3"/>

    <Style x:Key="FloatingButton" TargetType="Button">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="0,0,4,4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>