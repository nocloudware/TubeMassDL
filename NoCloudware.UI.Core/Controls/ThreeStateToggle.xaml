<UserControl x:Class="NoCloudware.UI.Core.Controls.ThreeStateToggle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:NoCloudware.UI.Core.Controls"
             mc:Ignorable="d"
             d:DesignHeight="36" d:DesignWidth="200">

    <Grid x:Name="RootGrid" Height="{Binding ToggleHeight, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Track background -->
        <Border Grid.Column="0" Grid.ColumnSpan="3"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="8"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"/>

        <!-- Thumb -->
        <Border x:Name="Thumb"
                Grid.Column="0"
                Margin="{Binding ThumbMargin, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CornerRadius="{Binding ThumbCornerRadius, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Background="{DynamicResource AccentBrush}"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform X="0"/>
            </Border.RenderTransform>
        </Border>

        <!-- Labels -->
        <Button x:Name="HighButton"
                Grid.Column="0"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Foreground="{DynamicResource TextPrimaryBrush}"
                FontSize="12"
                FontWeight="SemiBold"
                Content="{Binding HighLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Click="HighButton_Click"/>
        <Button x:Name="MediumButton"
                Grid.Column="1"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Foreground="{DynamicResource TextPrimaryBrush}"
                FontSize="12"
                FontWeight="SemiBold"
                Content="{Binding MediumLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Click="MediumButton_Click"/>
        <Button x:Name="LowButton"
                Grid.Column="2"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Foreground="{DynamicResource TextPrimaryBrush}"
                FontSize="12"
                FontWeight="SemiBold"
                Content="{Binding LowLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Click="LowButton_Click"/>
    </Grid>
</UserControl>
