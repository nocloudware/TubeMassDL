<UserControl x:Class="NoCloudware.UI.Core.Controls.ThemeToggle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ui:Button x:Name="ThemeButton"
               Appearance="Transparent"
                Width="{Binding ButtonWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Height="{Binding ButtonHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
               Click="ThemeButton_Click"
               Padding="0">
        <ui:SymbolIcon x:Name="ThemeIcon"
                       Symbol="WeatherMoon20"
                       FontSize="16"/>
    </ui:Button>
</UserControl>
