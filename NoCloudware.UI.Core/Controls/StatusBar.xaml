<UserControl x:Class="NoCloudware.UI.Core.Controls.StatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="32" d:DesignWidth="600">

    <Border Style="{StaticResource StatusBarStyle}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="TotalTextBlock"
                       Style="{StaticResource StatusCounterDefaultStyle}"/>
            <TextBlock x:Name="ProcessedTextBlock"
                       Style="{StaticResource StatusCounterPositiveStyle}"/>
            <TextBlock x:Name="PendingTextBlock"
                       Foreground="{DynamicResource StatusPendingBrush}"
                       Style="{StaticResource StatusCounterStyle}"/>
            <TextBlock x:Name="ErrorTextBlock"
                       Style="{StaticResource StatusCounterErrorStyle}"/>
        </StackPanel>
    </Border>
</UserControl>
