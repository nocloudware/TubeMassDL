<UserControl x:Class="NoCloudware.UI.Core.Controls.BaseMainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:NoCloudware.UI.Core.Controls"
             TextElement.FontFamily="Segoe UI Variable Text, Segoe UI"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">

    <Grid Margin="10" Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header (app name only; apps inject custom content in center column) ── -->
        <Grid Grid.Row="0">
            <!-- Banner (centered) -->
            <Image Source="pack://application:,,,/TubeMassDL;component/Resources/tubemassdl-banner.png"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   MaxHeight="70"
                   Margin="0,0,0,8"
                   MouseLeftButtonDown="OnHeaderMouseDown"/>

            <Grid Margin="0,0,0,8" MouseLeftButtonDown="OnHeaderMouseDown" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="AppTitleText"
                           FontSize="{Binding AppTitleFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <controls:LanguageSelector x:Name="LangSelector"
                                               Margin="0,0,6,0"/>
                    <controls:ThemeToggle x:Name="ThemeToggler"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ── Main content ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: File list (unified drop zone, like TurnAFile) + output folder -->
            <Border Grid.Column="0"
                    Style="{DynamicResource CardStyle}"
                    Padding="10"
                    Margin="0,0,8,0"
                    AllowDrop="True"
                    DragEnter="OnLeftPanelDragEnter"
                    Drop="OnLeftPanelDrop">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header: Selected files + count -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="Document24" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding FileListHeader, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="FileCountText"
                                   Margin="8,0,0,0"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!-- File list area (handles drag & drop) -->
                    <Grid Grid.Row="1">
                        <controls:FileListBox x:Name="FileList"
                                              FilesDropped="OnFilesDroppedCore"/>
                        <TextBlock x:Name="EmptyListText"
                                   Text="{Binding DropText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Select files button -->
                    <ui:Button Grid.Row="2"
                               Click="OnSelectFiles"
                               Appearance="Secondary"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               Visibility="{Binding ShowSelectFilesButton, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Content="{Binding SelectFilesButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="DocumentAdd24"/>
                        </ui:Button.Icon>
                    </ui:Button>

                    <!-- Output folder selector -->
                    <Border Grid.Row="3"
                            Background="{DynamicResource SurfaceAltBrush}"
                            CornerRadius="6"
                            Padding="8,6"
                            Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ui:SymbolIcon Grid.Column="0"
                                           Symbol="Folder24"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>

                            <TextBlock x:Name="OutputFolderTextBlock"
                                       Grid.Column="1"
                                       Text="{Binding OutputFolderText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>

                            <ui:Button Grid.Column="2"
                                       Click="OnSelectOutputFolder"
                                       Appearance="Transparent"
                                       Padding="6,2"
                                       Margin="8,0,0,0"
                                       Content="{Binding ChangeButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right: Options panel placeholder -->
            <Border Grid.Column="1"
                    Style="{DynamicResource CardStyle}"
                    Padding="{Binding OptionsPanelPadding, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    MinWidth="{Binding OptionsPanelMinWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    x:Name="OptionsPanelBorder"
                    Grid.RowSpan="2">
                <ContentControl x:Name="OptionsPanel"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"/>
            </Border>
        </Grid>

        <!-- ── Status + Progress bar ── -->
        <Border Grid.Row="2" Background="Transparent" Padding="0,4">
            <StackPanel>
                <controls:StatusBar x:Name="StatusBarControl"
                                    HorizontalAlignment="Center"/>
                <ProgressBar Value="{Binding GlobalProgress, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             Maximum="{Binding GlobalProgressMax, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             Visibility="{Binding GlobalProgressVisible, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             Height="6"
                             Margin="0,4,0,0"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource SurfaceAltBrush}"
                             BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- ── Bottom bar ── -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ui:Button Grid.Column="0"
                       Click="OnAboutClick"
                       Appearance="Transparent"
                       Padding="6,4"
                       Content="{Binding AboutButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Info20"/>
                </ui:Button.Icon>
            </ui:Button>

            <ui:Button Grid.Column="1"
                       Click="OnDonateClick"
                       Appearance="Transparent"
                       Padding="6,4"
                       MinWidth="80"
                       Visibility="{Binding DonateButtonVisible, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Content="{Binding DonateButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Money24" Foreground="{DynamicResource AccentBrush}"/>
                </ui:Button.Icon>
            </ui:Button>

            <!-- Tips: clickable, green, shows rotating list -->
            <TextBlock x:Name="TipsTextBlock"
                       Grid.Column="2"
                       Text="{Binding CurrentTip, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Foreground="{DynamicResource AccentBrush}"
                       FontSize="{Binding TipsFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Cursor="Hand"
                       MouseLeftButtonDown="OnTipsClick"/>

            <ui:Button Grid.Column="3"
                       Click="OnActionClick"
                       Appearance="Primary"
                       Margin="0,0,6,0"
                       MinWidth="{Binding ActionButtonMinWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Content="{Binding ActionButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowSyncCircle20"/>
                </ui:Button.Icon>
            </ui:Button>

            <ui:Button Grid.Column="4"
                       Click="OnExitClick"
                       Appearance="Secondary"
                       Content="{Binding ExitButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="ArrowExit20"/>
                </ui:Button.Icon>
            </ui:Button>
        </Grid>
    </Grid>
</UserControl>