<Window x:Class="NoCloudware.UI.Core.Controls.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:Name="AboutDialogWindow"
        mc:Ignorable="d"
        Title="{Binding DialogTitle, RelativeSource={RelativeSource Self}}"
        Width="{Binding DialogWidth, RelativeSource={RelativeSource Self}}" Height="{Binding DialogHeight, RelativeSource={RelativeSource Self}}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Border x:Name="LogoBorder"
                    Width="{Binding LogoFrameWidth, RelativeSource={RelativeSource AncestorType=Window}}" Height="{Binding LogoFrameHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                    CornerRadius="{Binding LogoCornerRadius, RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="{DynamicResource AccentBrush}"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,12">
                <Image x:Name="LogoImage"
                       Width="{Binding LogoImageWidth, RelativeSource={RelativeSource AncestorType=Window}}" Height="{Binding LogoImageHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            <TextBlock x:Name="AppNameTextBlock"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="AppVersionTextBlock"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Separator -->
        <Separator Grid.Row="1" Margin="0,0,0,12"
                   VerticalAlignment="Top"
                   Background="{DynamicResource BorderBrush}"/>

        <!-- Body -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,4,0,0">
            <StackPanel>
                <TextBlock x:Name="CopyrightTextBlock"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"/>

                <TextBlock Text="{Binding ThirdPartyHeader, RelativeSource={RelativeSource AncestorType=Window}}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,0,0,8"/>
                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Padding="12"
                        MaxHeight="220">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="LicensesTextBlock"
                                   FontSize="10"
                                   FontFamily="Consolas, Courier New"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="CheckUpdatesButton"
                    Content="{Binding CheckUpdatesText, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Margin="0,0,8,0"
                    Click="CheckUpdatesButton_Click"/>
            <Button x:Name="CloseButton"
                    Content="{Binding CloseButtonText, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
