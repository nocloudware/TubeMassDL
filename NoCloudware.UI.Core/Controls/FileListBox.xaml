<UserControl x:Class="NoCloudware.UI.Core.Controls.FileListBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="FileListBoxRoot">
    <ListBox x:Name="FileListBoxControl"
             Background="Transparent"
             BorderThickness="0"
             AllowDrop="True"
             ItemsSource="{Binding Items, RelativeSource={RelativeSource AncestorType=UserControl}}"
             DragEnter="OnDragEnter"
             Drop="OnDrop"
              ContextMenuOpening="OnContextMenuOpening"
              VirtualizingPanel.ScrollUnit="Pixel"
             ScrollViewer.CanContentScroll="True"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
             ScrollViewer.VerticalScrollBarVisibility="Auto">
        <ListBox.Style>
            <Style TargetType="ListBox" BasedOn="{StaticResource AetherFileListBoxStyle}">
                <Setter Property="AllowDrop" Value="True"/>
            </Style>
        </ListBox.Style>
        <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="1,0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="MinHeight" Value="16"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="11"/>
                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OnItemPreviewMouseDown"/>
            </Style>
        </ListBox.ItemContainerStyle>
        <ListBox.ItemTemplate>
            <DataTemplate>
                <Grid Margin="0" MinHeight="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>

                    <!-- Name (already includes 🎬/📁 and tree chars) -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding FileName}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="2,0,2,0"
                               FontSize="11"/>

                    <!-- Extension (or playlist item count) -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Converter={StaticResource PlaylistCountConverter}}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="9"
                               VerticalAlignment="Center"
                               TextAlignment="Center"/>

                    <!-- Size -->
                    <TextBlock Grid.Column="2"
                               Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="9"
                               VerticalAlignment="Center"
                               TextAlignment="Center"/>

                    <!-- Progress % -->
                    <TextBlock Grid.Column="3"
                               Text="{Binding Progress, StringFormat={}{0}%}"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="9"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextAlignment="Center"/>

                    <!-- Status dot -->
                    <Ellipse Grid.Column="4"
                             Width="7" Height="7"
                             Fill="{Binding Status, Converter={StaticResource StatusDotColorConverter}}"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"/>

                    <!-- Delete ✕ -->
                    <Button Grid.Column="5"
                            Content="✕"
                            FontSize="9"
                            Foreground="{DynamicResource StatusErrorBrush}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="0"
                            Width="16" Height="16"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Command="{Binding DeleteCommand}"
                            ToolTip="Remove"/>
                </Grid>
            </DataTemplate>
        </ListBox.ItemTemplate>
        <ListBox.ContextMenu>
            <ContextMenu>
                <MenuItem Header="{Binding RemoveMenuItemText, RelativeSource={RelativeSource AncestorType=UserControl}}" Click="OnRemoveClicked"/>
                <MenuItem Header="{Binding ClearAllMenuItemText, RelativeSource={RelativeSource AncestorType=UserControl}}" Click="OnClearAllClicked"/>
            </ContextMenu>
        </ListBox.ContextMenu>
    </ListBox>
</UserControl>
